---
import { Icon } from "astro-icon/components";

import Button from "@/components/button/Button.astro";
import FaqAccordionsLarge from "@/components/faq/FaqAccordionsLarge.astro";
import NewsletterSignup from "@/components/newsletter/NewsletterSignup.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const ways = [
  {
    icon: "tabler/mail",
    title: "Join the newsletter",
    description:
      "The easiest way to help: stay informed. Plain-language updates on the bills shaping how California communities rebuild — and what you can do about them.",
    cta: { label: "Sign up below", href: "#newsletter" },
  },
  {
    icon: "tabler/users",
    title: "Volunteer",
    description:
      "Researchers, writers, organizers, planners, attorneys, and neighbors who can knock on a door or forward an email — every skill has a place here. Tell us what you'd like to do.",
    cta: {
      label: "Email us",
      href: "mailto:info@rrpn.org?subject=Volunteering%20with%20RRPN",
    },
  },
  {
    icon: "tabler/building-community",
    title: "Partner with us",
    description:
      "Community groups, civic organizations, researchers, and funders: if your work touches the intersection of state law and local land use, let's talk about working together.",
    cta: {
      label: "Start the conversation",
      href: "mailto:info@rrpn.org?subject=Partnering%20with%20RRPN",
    },
  },
];
---

<BaseLayout
  title="Get Involved"
  description="Join the RRPN newsletter, volunteer your time or expertise, or partner with us on planning policy that respects both statewide goals and community self-determination."
>
  <section class="bg-primary-700">
    <div class="site-container pt-36 pb-16 md:pt-44 md:pb-20">
      <h1 class="h1 text-base-50 max-w-3xl">Get involved</h1>
      <p class="text-primary-100 mt-4 max-w-2xl text-lg">
        Good planning policy doesn't happen without the people it affects. There's a place for you
        here.
      </p>
    </div>
  </section>

  <section class="site-container py-16 md:py-24" aria-label="Ways to get involved">
    <div class="grid gap-8 md:grid-cols-3">
      {
        ways.map((way, idx) => (
          <div
            class="border-border bg-base-50 flex flex-col rounded-lg border p-8 shadow-sm"
            data-mos="fade-up"
            data-mos-delay={`${idx * 0.1}`}
          >
            <div class="bg-primary-100 text-primary mb-5 flex h-12 w-12 items-center justify-center rounded-md">
              <Icon name={way.icon} class="h-6 w-6" aria-hidden="true" />
            </div>
            <h2 class="h3 text-primary">{way.title}</h2>
            <p class="text-muted-foreground mt-3 grow">{way.description}</p>
            <div class="mt-6">
              <Button href={way.cta.href} variant="outline">
                {way.cta.label}
              </Button>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <NewsletterSignup />

  <FaqAccordionsLarge />
</BaseLayout>
