---
import NewsletterSignup from "@/components/newsletter/NewsletterSignup.astro";
import FaqAccordionsLarge from "@/components/faq/FaqAccordionsLarge.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Get Involved"
  description="Join the RRPN newsletter for plain-language updates on the state legislation shaping how California communities recover, rebuild, and stay resilient."
>
  <section class="bg-primary-700">
    <div class="site-container pt-36 pb-16 md:pt-44 md:pb-20">
      <h1 class="h1 text-base-50 max-w-3xl">Get involved</h1>
      <p class="text-primary-100 mt-4 max-w-2xl text-lg">
        The simplest way to help is to stay informed. Join the newsletter below for plain-language
        updates on the bills shaping how California communities recover and rebuild. To volunteer or
        partner with us, just email
        <a class="text-base-50 underline" href="mailto:info@rrpn.org">info@rrpn.org</a>.
      </p>
    </div>
  </section>

  <NewsletterSignup />

  <FaqAccordionsLarge />
</BaseLayout>
