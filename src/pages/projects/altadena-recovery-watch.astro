---
/**
 * Altadena Recovery Watch project page.
 * Voice note: per the brand package, project pages carry the grassroots register —
 * direct, urgent, neighbor-to-neighbor. "We" = the community.
 */
import { Image } from "astro:assets";

import Button from "@/components/button/Button.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import arwAerialHero from "@images/arw-aerial-hero.jpg";
import arwParcelFigure from "@images/arw-parcel-figure.jpg";
---

<BaseLayout
  title="Altadena Recovery Watch"
  description="Altadena Recovery Watch grew out of the 2025 Eaton Fire and engages thousands of residents on the state legislation — including SB 1090, SB 1123, and the SB 254 wildfire fund — shaping how our community recovers and rebuilds."
>
  <!-- Page header -->
  <section class="bg-accent-800">
    <div class="site-container pt-36 pb-16 md:pt-44 md:pb-20">
      <p class="text-accent-200 mb-3 text-sm font-medium tracking-widest uppercase">
        An RRPN community project
      </p>
      <h1 class="h1 text-base-50 max-w-3xl">Altadena Recovery Watch</h1>
      <p class="text-accent-100 mt-4 max-w-2xl text-lg">
        Lost homes, not lost voices. Altadena Recovery Watch keeps our neighbors informed — and
        heard — on the state laws deciding how we rebuild.
      </p>
    </div>
  </section>

  <!-- Hero photography -->
  <section class="site-container -mt-10 md:-mt-14">
    <div class="mx-auto max-w-4xl overflow-hidden rounded-lg border border-border shadow-sm">
      <Image
        src={arwAerialHero}
        alt="Aerial view of an Altadena neighborhood block with a vacant, fire-cleared lot outlined amid surviving tree canopy and rebuilding homes"
        class="h-full w-full object-cover"
        width={1400}
      />
    </div>
  </section>

  <section class="site-container py-16 md:py-24">
    <div class="mx-auto max-w-3xl space-y-12">
      <div>
        <h2 class="h2 text-primary">Where we started</h2>
        <div class="mt-5 space-y-5 leading-relaxed">
          <p>
            The 2025 Eaton Fire took thousands of Altadena homes in a single night — and our
            community quickly learned that the rules for how, and whether, we rebuild are written
            far from our neighborhood, in Sacramento. Altadena Recovery Watch began as neighbors
            keeping each other informed. It has grown into a network of thousands who follow the
            legislation shaping our recovery, show up, and make sure Altadena's voice is in the room.
          </p>
        </div>
      </div>

      <div>
        <h2 class="h2 text-primary">What we're watching</h2>
        <div class="mt-5 space-y-5 leading-relaxed">
          <p>
            Right now, we're tracking state legislation with direct consequences for fire-recovery
            communities. That includes land-use and rebuilding bills like <strong>SB 1090</strong>
            and <strong>SB 1123</strong> — which touch how land in rebuilding neighborhoods can be
            developed and who decides — and wildfire-fund and utility measures like
            <strong>SB 254</strong> that shape who pays for recovery. We read the bills, we translate
            them into plain language,
            and we tell our neighbors what they say, what changed, and what it means for the street
            you live on.
          </p>
          <p>
            Plain-language explainers are posted on RRPN's
            <a class="text-terracotta-600 underline hover:no-underline" href="/updates">Updates</a>
            page as bills move.
          </p>
        </div>
        <figure class="mt-8">
          <Image
            src={arwParcelFigure}
            alt="Aerial parcel map of a fire-cleared residential lot on E Altadena Drive, marked for tracking amid still-standing neighboring homes"
            class="w-full rounded-lg border border-border"
            width={1200}
          />
          <figcaption class="text-muted-foreground mt-3 text-sm">
            One of thousands of Altadena lots cleared by the Eaton Fire and now awaiting rebuilding
            — the kind of parcel directly affected by the state legislation ARW tracks.
          </figcaption>
        </figure>
      </div>

      <div>
        <h2 class="h2 text-primary">Join us</h2>
        <div class="mt-5 space-y-5 leading-relaxed">
          <p>
            If you live in Altadena — or you're rebuilding anywhere in California and facing the
            same collision between state law and your community's recovery — you belong here. Sign
            up for updates, volunteer an hour, or just forward an explainer to a neighbor who needs
            it.
          </p>
        </div>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/get-involved" variant="secondary" arrow="right">Get involved</Button>
          <Button href="/updates" variant="outline">Read the updates</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
