---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Press & Media Kit"
  description="Media resources for covering the Responsible and Resilient Planning Network (RRPN): boilerplate, founder bio, key facts, and press contact."
>
  <section class="bg-primary-700">
    <div class="site-container pt-36 pb-16 md:pt-44 md:pb-20">
      <h1 class="h1 text-base-50 max-w-3xl">Press &amp; Media Kit</h1>
      <p class="text-primary-100 mt-4 max-w-2xl text-lg">
        Resources for journalists covering RRPN and its projects.
      </p>
    </div>
  </section>

  <section class="site-container py-16 md:py-24">
    <div class="mx-auto max-w-3xl space-y-14">
      <!-- Boilerplate -->
      <div>
        <h2 class="h2 text-primary">About RRPN (boilerplate)</h2>
        <p class="mt-5 leading-relaxed">
          The Responsible and Resilient Planning Network (RRPN) develops best-practices policy,
          advocacy, and education at the intersection of state law and local land use — so
          communities can rebuild, adapt, and thrive. RRPN operates as a portfolio of community
          projects; its first, Altadena Recovery Watch, grew out of the 2025 Eaton Fire and engages
          thousands of residents on the state land-use legislation shaping their rebuilding. Learn
          more at rrpn.org.
        </p>
      </div>

      <!-- Founder short bio -->
      <div>
        <h2 class="h2 text-primary">Founder bio</h2>
        <p class="mt-5 leading-relaxed">
          Noel Hyun Minor is the founder of the Responsible and Resilient Planning Network (RRPN).
          A former LA City Hall planning deputy, registered lobbyist, and land use attorney (Liner
          LLP, DLA Piper), she leads The Brooklyn Companies family office and serves on the
          Altadena Town &amp; Country Club Board of Governors. She holds a J.D. from USC Gould
          School of Law.
        </p>
        <p class="text-muted-foreground mt-3 text-sm">
          A downloadable headshot will be posted here.
          <!-- TODO (Noel): add approved headshot download (same image as About page / LinkedIn). -->
        </p>
      </div>

      <!-- Key facts -->
      <div>
        <h2 class="h2 text-primary">Key facts</h2>
        <ul class="mt-5 list-disc space-y-2 pl-6 leading-relaxed">
          <li>
            <strong>Name:</strong> Responsible and Resilient Planning Network (RRPN)
          </li>
          <li><strong>Founded:</strong> 2026, Altadena, California</li>
          <li><strong>Founder:</strong> Noel Hyun Minor</li>
          <li>
            <strong>Focus:</strong> policy research, advocacy, and education at the intersection of
            state law and local land use
          </li>
          <li>
            <strong>First project:</strong> Altadena Recovery Watch — born of the 2025 Eaton Fire,
            engaging thousands of residents on state land-use legislation (including SB 1090 and SB
            1123) affecting rebuilding communities
          </li>
          <li>
            <strong>Status:</strong> newly formed; legal formation in progress
          </li>
        </ul>
      </div>

      <!-- Logo assets -->
      <div>
        <h2 class="h2 text-primary">Logos</h2>
        <p class="text-muted-foreground mt-5 leading-relaxed">
          Downloadable logo files (full-color, one-color, and on-dark versions) will be posted here
          once RRPN's final mark is complete.
          <!-- TODO (Noel): add final logo files (SVG + PNG, light/dark) when the logo is finalized. -->
        </p>
        <div
          class="border-border bg-base-100 mt-4 flex h-32 items-center justify-center rounded-lg border border-dashed"
        >
          <p class="text-muted-foreground text-sm">Logo downloads coming soon</p>
        </div>
      </div>

      <!-- Press contact -->
      <div>
        <h2 class="h2 text-primary">Press contact</h2>
        <p class="mt-5 leading-relaxed">
          For interviews, background, or comment:
          <a
            class="text-terracotta-600 underline hover:no-underline"
            href="mailto:info@rrpn.org?subject=Press%20inquiry">info@rrpn.org</a
          >. Please include your outlet and deadline.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
