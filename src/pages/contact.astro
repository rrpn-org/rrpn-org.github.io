---
import Button from "@/components/button/Button.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Contact the Responsible Recovery Planning Network at info@rrpn.org."
>
  <section class="bg-primary-700">
    <div class="site-container pt-36 pb-16 md:pt-44 md:pb-20">
      <h1 class="h1 text-base-50 max-w-3xl">Contact</h1>
      <p class="text-primary-100 mt-4 max-w-2xl text-lg">
        Questions, ideas, or press — we read everything sent to
        <a class="text-base-50 underline" href="mailto:info@rrpn.org">info@rrpn.org</a>.
      </p>
    </div>
  </section>

  <section class="site-container py-16 md:py-24">
    <div class="bg-base-100 border-border mx-auto max-w-2xl rounded-lg border p-8 text-center">
      <h2 class="h3 text-primary">Responsible Recovery Planning Network</h2>
      <p class="text-muted-foreground mt-3">
        Altadena, California &middot;
        <a class="text-terracotta-600 underline hover:no-underline" href="mailto:info@rrpn.org"
          >info@rrpn.org</a
        >
      </p>
      <div class="mt-6 flex justify-center">
        <Button href="mailto:info@rrpn.org" variant="primary">Email info@rrpn.org</Button>
      </div>
    </div>
  </section>
</BaseLayout>
