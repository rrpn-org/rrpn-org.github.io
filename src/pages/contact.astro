---
/**
 * Contact page.
 * Note: the theme's demo contact form had no backend, so this page uses direct
 * mailto links instead of a form that silently goes nowhere. If Noel later adds a
 * form backend (e.g. Formspark, Netlify/Cloudflare forms, EmailOctopus), the theme's
 * form components are still available at src/components/forms/ContactForm.astro.
 */
import { Icon } from "astro-icon/components";

import Button from "@/components/button/Button.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const inquiryTypes = [
  {
    icon: "tabler/mail",
    title: "General inquiries",
    description: "Questions about RRPN, our research, or our projects.",
    href: "mailto:info@rrpn.org?subject=General%20inquiry",
  },
  {
    icon: "tabler/users",
    title: "Volunteering & partnership",
    description: "Offer your time or explore working together.",
    href: "mailto:info@rrpn.org?subject=Getting%20involved",
  },
  {
    icon: "tabler/pencil",
    title: "Press",
    description: "Interviews, background, or comment — include your outlet and deadline.",
    href: "mailto:info@rrpn.org?subject=Press%20inquiry",
  },
];
---

<BaseLayout
  title="Contact"
  description="Contact the Responsible and Resilient Planning Network at info@rrpn.org — general inquiries, volunteering, partnership, and press."
>
  <section class="bg-primary-700">
    <div class="site-container pt-36 pb-16 md:pt-44 md:pb-20">
      <h1 class="h1 text-base-50 max-w-3xl">Contact</h1>
      <p class="text-primary-100 mt-4 max-w-2xl text-lg">
        We read everything sent to
        <a class="text-base-50 underline" href="mailto:info@rrpn.org">info@rrpn.org</a>.
      </p>
    </div>
  </section>

  <section class="site-container py-16 md:py-24">
    <div class="mx-auto max-w-4xl">
      <div class="grid gap-8 md:grid-cols-3">
        {
          inquiryTypes.map((item) => (
            <a
              href={item.href}
              class="border-border bg-base-50 hover:border-primary-300 group rounded-lg border p-8 shadow-sm transition"
            >
              <div class="bg-primary-100 text-primary mb-5 flex h-12 w-12 items-center justify-center rounded-md">
                <Icon name={item.icon} class="h-6 w-6" aria-hidden="true" />
              </div>
              <h2 class="h3 text-primary">{item.title}</h2>
              <p class="text-muted-foreground mt-3">{item.description}</p>
              <p class="text-terracotta-600 mt-4 text-sm font-medium group-hover:underline">
                Email us &rarr;
              </p>
            </a>
          ))
        }
      </div>

      <div class="bg-base-100 border-border mx-auto mt-16 max-w-2xl rounded-lg border p-8 text-center">
        <h2 class="h3 text-primary">Responsible and Resilient Planning Network</h2>
        <p class="text-muted-foreground mt-3">
          Altadena, California &middot;
          <a
            class="text-terracotta-600 underline hover:no-underline"
            href="mailto:info@rrpn.org">info@rrpn.org</a
          >
        </p>
        <div class="mt-6 flex justify-center">
          <Button href="mailto:info@rrpn.org" variant="primary">Email info@rrpn.org</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
