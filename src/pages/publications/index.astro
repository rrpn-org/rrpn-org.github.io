---
import { getCollection } from "astro:content";

import { getLocaleFromUrl } from "@/js/localeUtils";
import { formatDate } from "@/js/textUtils";
import BaseLayout from "@/layouts/BaseLayout.astro";

const currLocale = getLocaleFromUrl(Astro.url);

const publications = (await getCollection("publications", ({ data }) => data.draft !== true)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="Publications"
  description="RRPN's research library: best-practices policy research on housing law, disaster recovery, climate adaptation, and the intersection of state law and local land use."
>
  <section class="bg-primary-700">
    <div class="site-container pt-36 pb-16 md:pt-44 md:pb-20">
      <h1 class="h1 text-base-50 max-w-3xl">Publications</h1>
      <p class="text-primary-100 mt-4 max-w-2xl text-lg">
        Rigorous, best-practices policy research — written to be read, cited, and used.
      </p>
    </div>
  </section>

  <section class="site-container py-16 md:py-24">
    <div class="mx-auto max-w-3xl">
      <div class="bg-base-100 border-border rounded-lg border p-6">
        <p class="font-medium">Research library launching soon.</p>
        <p class="text-muted-foreground mt-2">
          RRPN's first publications are in progress. Forthcoming titles are listed below; sign up
          for the <a class="text-terracotta-600 underline hover:no-underline" href="/get-involved#newsletter"
            >newsletter</a
          > to be notified when they're released.
        </p>
      </div>

      <ul class="mt-12 space-y-8">
        {
          publications.map((entry) => (
            <li class="border-border border-b pb-8">
              <a class="group" href={`/publications/${entry.id}/`}>
                <p class="text-muted-foreground text-sm">
                  {formatDate(entry.data.pubDate, currLocale)}
                  {entry.data.status === "forthcoming" && (
                    <span class="bg-accent-100 text-accent-900 ml-2 rounded-sm px-1.5 py-0.5 text-xs font-semibold tracking-wide uppercase">
                      Forthcoming
                    </span>
                  )}
                  {entry.data.reviewStatus === "draft" && (
                    <span class="bg-warning text-warning-foreground ml-2 rounded-sm px-1.5 py-0.5 text-xs font-semibold tracking-wide uppercase">
                      Draft
                    </span>
                  )}
                </p>
                <h2 class="h3 group-hover:text-primary mt-2 transition">{entry.data.title}</h2>
                <p class="text-muted-foreground mt-2">{entry.data.description}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
